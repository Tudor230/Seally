# LiveKit server URL (WebSocket)
VITE_LIVEKIT_URL=wss://your-project.livekit.cloud

# LiveKit API credentials for token generation
# Get these from your LiveKit Cloud dashboard at https://cloud.livekit.io
VITE_LIVEKIT_API_KEY=your_api_key_here
VITE_LIVEKIT_API_SECRET=your_api_secret_here

# Optional: Landmark data topic
VITE_LIVEKIT_LANDMARK_TOPIC=pose.binary.v2

# Optional: Force relay mode (default: true)
VITE_LIVEKIT_FORCE_RELAY=false
